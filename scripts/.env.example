# RunPod API credentials
RUNPOD_API_KEY=rpa_your_api_key_here
RUNPOD_ENDPOINT_ID=your_endpoint_id_here

# GitLab deploy token (clone du repo prive depuis le pod RunPod)
# Cf. GitLab > Settings > Repository > Deploy tokens (scope: read_repository)
# Le username change a chaque regeneration du token : gitlab+deploy-token-<id>
GITLAB_DEPLOY_USER=gitlab+deploy-token-XXXXXXXX
GITLAB_DEPLOY_TOKEN=***REMOVED_GITLAB_DEPLOY_TOKEN***
GITLAB_REPO=medusa7293008/medusa_i2v_adapter
